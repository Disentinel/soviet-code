    "start": "node dist/cli.js"
  },
  "keywords": [
    "ai",
    "claude",
    "anthropic",
    "code-review",
    "cli",
    "typescript",
    "developer-tools",
    "workflow",
    "planning",
    "agent",
    "llm",
    "automation"
  ],
