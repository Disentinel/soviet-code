  "license": "MIT",
  "files": [
    "dist/",
    "conductor/dist/",
    "gosplan.yaml",
    "README.md",
    "LICENSE",
    "IDEOLOGY.md",
    "CONTRIBUTING.md"
  ],
  "homepage": "https://disentinel.github.io/soviet-code/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Disentinel/soviet-code.git"
  },
  "bugs": {
    "url": "https://github.com/Disentinel/soviet-code/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
